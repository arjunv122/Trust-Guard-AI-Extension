# Flask Configuration
FLASK_ENV=development
PORT=5001
SECRET_KEY=your-secret-key-here

# Groq API (for LLM-based hallucination detection)
GROQ_API_KEY=your-groq-api-key-here

# Hugging Face API (for media/deepfake detection)
HF_API_TOKEN=your-huggingface-token-here

# OpenAI API (Optional - for better sample generation)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic Claude API (Optional - for fact-checking)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# MongoDB (if using authentication)
MONGODB_URI=mongodb://localhost:27017/trustguard

# CORS Settings
CLIENT_URL=http://localhost:8080
